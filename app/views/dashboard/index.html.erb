<div class="max-w-4xl mx-auto p-6">

  <!-- ページタイトル -->
  <h1 class="text-2xl font-bold mb-6 text-center">
    <%= t("views.dashboard.title") %>
  </h1>

  <!-- ユーザー情報 -->
  <div class="mb-8 text-center">
    <p class="text-gray-700">
      <%= t("views.dashboard.welcome") %>
      <span class="font-semibold">
        <%= current_user.name %>
      </span>
      <%= t("views.shared.header.user_suffix") %>
    </p>
    <p class="text-sm text-gray-500 mt-1">
      <%= t("views.dashboard.message") %>
    </p>
  </div>

  <!-- メイン導線 -->
  <div class="grid gap-4 sm:grid-cols-2">

    <!-- イベント作成 -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title"><%= t("views.dashboard.cards.events_new_title") %></h2>
        <p class="text-sm text-gray-600">
          <%= t("views.dashboard.cards.events_new_desc") %>
        </p>
        <div class="card-actions justify-end">
          <%= link_to t("views.dashboard.cards.events_new_link"), new_event_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>

    <!-- イベント一覧 -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title"><%= t("views.dashboard.cards.events_index_title") %></h2>
        <p class="text-sm text-gray-600">
          <%= t("views.dashboard.cards.events_index_desc") %>
        </p>
        <div class="card-actions justify-end">
          <%= link_to t("views.dashboard.cards.index_link"), events_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>

    <!-- お店ログ（下中央） -->
    <div class="sm:col-span-2 flex justify-center">
      <div class="w-full sm:w-1/2">
        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <h2 class="card-title"><%= t("views.dashboard.cards.shop_logs_title") %></h2>
            <p class="text-sm text-gray-600">
              <%= t("views.dashboard.cards.shop_logs_desc") %>
            </p>
            <div class="card-actions justify-end">
              <%= link_to t("views.dashboard.cards.index_link"), shop_logs_path, class: "btn btn-primary" %>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
