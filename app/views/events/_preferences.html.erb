<div class="mt-8">
  <div class="rounded-xl border border-base-300 bg-base-100 p-4 space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-semibold"><%= t("views.events.preferences.title") %></h2>

      <% if participating %>
        <label for="event-preference-modal" class="btn btn-primary btn-sm">
          <%= t("views.events.preferences.open_form") %>
        </label>
      <% end %>
    </div>

    <% if event_preferences.any? %>
      <div class="max-h-72 overflow-y-auto">
        <div class="grid gap-3 lg:grid-cols-2">
          <% event_preferences.each do |event_preference| %>
            <div class="rounded-lg border border-base-200 bg-base-100 p-3 space-y-2">
              <% if event_preference.user_id == current_user.id %>
                <p class="text-xs text-primary font-bold"><%= t("views.events.preferences.your_post") %></p>
              <% end %>

              <div>
                <p class="text-sm text-gray-500"><%= t("views.events.preferences.dislike_foods") %></p>
                <p><%= event_preference.dislike_foods.presence || t("views.events.preferences.none") %></p>
              </div>

              <div>
                <p class="text-sm text-gray-500"><%= t("views.events.preferences.budget") %></p>
                <p><%= event_preference.budget_label %></p>
              </div>

              <div>
                <p class="text-sm text-gray-500"><%= t("views.events.preferences.content") %></p>
                <p class="whitespace-pre-wrap">
                  <%= event_preference.content.presence || t("views.events.preferences.none") %>
                </p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-500"><%= t("views.events.preferences.empty") %></p>
    <% end %>

    <% if participating %>
      <input type="checkbox" id="event-preference-modal" class="modal-toggle" />

      <div class="modal" role="dialog">
        <div class="modal-box max-w-lg">
          <h3 class="text-lg font-bold"><%= t("views.events.preferences.open_form") %></h3>

          <%= form_with model: event_preference,
                        url: event_event_preferences_path(event),
                        method: :post,
                        local: true do |f| %>

            <div class="mt-4 space-y-4">

              <div class="form-control">
                <%= f.label :dislike_foods, t("views.events.preferences.dislike_foods"), class: "label" %>
                <%= f.text_area :dislike_foods, class: "textarea textarea-bordered w-full", rows: 3 %>
              </div>

              <div class="form-control">
                <%= f.label :budget, t("views.events.preferences.budget"), class: "label" %>
                <%= f.select :budget,
                  [
                    [t("views.events.preferences.select_budget"), nil],
                    [t("views.events.preferences.option_1"), 1],
                    [t("views.events.preferences.option_2"), 2],
                    [t("views.events.preferences.option_3"), 3],
                    [t("views.events.preferences.option_4"), 4],
                    [t("views.events.preferences.option_5"), 5]
                  ],
                  {},
                  class: "select select-bordered w-full" %>
              </div>

              <div class="form-control">
                <%= f.label :content, t("views.events.preferences.other"), class: "label" %>
                <%= f.text_area :content, class: "textarea textarea-bordered w-full", rows: 4 %>
              </div>

              <div class="modal-action">
                <% if event_preference.persisted? %>
                  <%= link_to t("views.events.preferences.delete"),
                    event_event_preference_path(event, event_preference),
                    data: { turbo_method: :delete, turbo_confirm: t("views.events.preferences.delete_confirm") },
                    class: "btn btn-error" %>
                <% end %>

                <%= f.submit t("common.save"), class: "btn btn-primary" %>
                <label for="event-preference-modal" class="btn btn-ghost"><%= t("common.cancel") %></label>
              </div>

            </div>
          <% end %>
        </div>

        <label class="modal-backdrop" for="event-preference-modal"><%= t("views.events.preferences.close") %></label>
      </div>
    <% end %>

  </div>
</div>
