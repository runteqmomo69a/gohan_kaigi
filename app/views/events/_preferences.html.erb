<section class="card bg-base-100/95 border border-[#d7cdbc] shadow-xl shadow-amber-100/40 overflow-hidden">
  <div class="card-body p-6 sm:p-7 space-y-5">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#fff6dc] text-[#c78a12]">
          <span class="material-symbols-outlined">tune</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-neutral-700"><%= t("views.events.preferences.title") %></h2>
          <p class="text-sm text-base-content/60"><%= t("views.events.preferences.description") %></p>
        </div>
      </div>

      <% if participating %>
        <label for="event-preference-modal" class="btn rounded-full bg-[#e3744b] text-white border-none hover:bg-[#cf643d] shadow-md shadow-orange-200/35">
          <%= t("views.events.preferences.open_form") %>
        </label>
      <% end %>
    </div>

    <% if event_preferences.any? %>
      <% dislike_foods_list = event_preferences.filter_map { |preference| preference.dislike_foods.presence } %>
      <% budget_groups = event_preferences.filter_map(&:budget_label).tally %>
      <% content_list = event_preferences.filter_map { |preference| preference.content.presence } %>

      <div class="grid gap-4 xl:grid-cols-3">
        <article class="rounded-[1.75rem] border border-[#e8d7a2] bg-gradient-to-br from-white to-[#fff8e8] p-5 space-y-4">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[#fff6dc] text-[#c78a12]">
              <span class="material-symbols-outlined">no_food</span>
            </div>
            <div>
              <h3 class="text-lg font-bold text-neutral-700"><%= t("views.events.preferences.dislike_foods") %></h3>
              <p class="text-sm text-base-content/55">みんなの苦手なもの</p>
            </div>
          </div>

          <% if dislike_foods_list.any? %>
            <div class="flex flex-wrap gap-2">
              <% dislike_foods_list.each do |dislike_foods| %>
                <span class="rounded-full bg-[#fff6dc] border border-[#e8d7a2] px-3 py-1.5 text-sm text-[#b07a10]">
                  <%= dislike_foods %>
                </span>
              <% end %>
            </div>
          <% else %>
            <div class="rounded-2xl bg-white/90 border border-[#e8d7a2] px-4 py-4 text-sm text-base-content/60">
              <%= t("views.events.preferences.none") %>
            </div>
          <% end %>
        </article>

        <article class="rounded-[1.75rem] border border-[#e8d7a2] bg-gradient-to-br from-white to-[#fff8e8] p-5 space-y-4">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[#fff6dc] text-[#c78a12]">
              <span class="material-symbols-outlined">payments</span>
            </div>
            <div>
              <h3 class="text-lg font-bold text-neutral-700"><%= t("views.events.preferences.budget") %></h3>
              <p class="text-sm text-base-content/55">予算のまとまり</p>
            </div>
          </div>

          <% if budget_groups.any? %>
            <div class="space-y-2">
              <% budget_groups.each do |budget_label, count| %>
                <div class="flex items-center justify-between rounded-2xl bg-white/90 border border-[#e8d7a2] px-4 py-3">
                  <span class="text-sm text-base-content/80"><%= budget_label %></span>
                  <span class="rounded-full bg-[#fff6dc] px-2.5 py-1 text-xs font-bold text-[#b07a10] border border-[#e8d7a2]">
                    <%= t("views.events.participants.count", count: count) %>
                  </span>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="rounded-2xl bg-white/90 border border-[#e8d7a2] px-4 py-4 text-sm text-base-content/60">
              <%= t("views.events.preferences.select_budget") %>
            </div>
          <% end %>
        </article>

        <article class="rounded-[1.75rem] border border-[#e8d7a2] bg-gradient-to-br from-white to-[#fff8e8] p-5 space-y-4">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[#fff6dc] text-[#c78a12]">
              <span class="material-symbols-outlined">edit_note</span>
            </div>
            <div>
              <h3 class="text-lg font-bold text-neutral-700"><%= t("views.events.preferences.other") %></h3>
              <p class="text-sm text-base-content/55"><%= t("views.events.preferences.content") %></p>
            </div>
          </div>

          <% if content_list.any? %>
            <div class="space-y-2 max-h-64 overflow-y-auto pr-1">
              <% content_list.each do |content| %>
                <div class="rounded-2xl bg-white/90 border border-[#e8d7a2] px-4 py-3">
                  <p class="whitespace-pre-wrap text-sm leading-relaxed text-base-content/80"><%= content %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="rounded-2xl bg-white/90 border border-[#e8d7a2] px-4 py-4 text-sm text-base-content/60">
              <%= t("views.events.preferences.none") %>
            </div>
          <% end %>
        </article>
      </div>
    <% else %>
      <div class="rounded-2xl bg-stone-50 border border-stone-200 px-4 py-4 text-sm text-base-content/60">
        <%= t("views.events.preferences.empty") %>
      </div>
    <% end %>

    <% if participating %>
      <input type="checkbox" id="event-preference-modal" class="modal-toggle" />

      <div class="modal" role="dialog">
        <div class="modal-box max-w-lg rounded-3xl border border-amber-100">
          <h3 class="text-xl font-bold text-neutral-700"><%= t("views.events.preferences.open_form") %></h3>

          <%= form_with model: event_preference,
                        url: event_event_preferences_path(event),
                        method: :post,
                        local: true do |f| %>

            <div class="mt-5 space-y-4">
              <div class="form-control">
                <%= f.label :dislike_foods, t("views.events.preferences.dislike_foods"), class: "label text-xs font-bold tracking-widest uppercase text-base-content/60" %>
                <%= f.text_area :dislike_foods, class: "textarea textarea-bordered w-full rounded-2xl bg-base-100", rows: 3 %>
              </div>

              <div class="form-control">
                <%= f.label :budget, t("views.events.preferences.budget"), class: "label text-xs font-bold tracking-widest uppercase text-base-content/60" %>
                <%= f.select :budget,
                  [
                    [t("views.events.preferences.select_budget"), nil],
                    [t("views.events.preferences.option_1"), 1],
                    [t("views.events.preferences.option_2"), 2],
                    [t("views.events.preferences.option_3"), 3],
                    [t("views.events.preferences.option_4"), 4],
                    [t("views.events.preferences.option_5"), 5]
                  ],
                  {},
                  class: "select select-bordered w-full rounded-2xl bg-base-100" %>
              </div>

              <div class="form-control">
                <%= f.label :content, t("views.events.preferences.other"), class: "label text-xs font-bold tracking-widest uppercase text-base-content/60" %>
                <%= f.text_area :content, class: "textarea textarea-bordered w-full rounded-2xl bg-base-100", rows: 4 %>
              </div>

              <div class="modal-action">
                <% if event_preference.persisted? %>
                  <%= link_to t("views.events.preferences.delete"),
                    event_event_preference_path(event, event_preference),
                    data: { turbo_method: :delete, turbo_confirm: t("views.events.preferences.delete_confirm") },
                    class: "btn rounded-full bg-red-50 text-red-600 border border-red-100 hover:bg-red-100" %>
                <% end %>

                <%= f.submit t("common.save"), class: "btn rounded-full bg-[#e3744b] text-white border-none hover:bg-[#cf643d]" %>
                <label for="event-preference-modal" class="btn btn-ghost rounded-full"><%= t("common.cancel") %></label>
              </div>
            </div>
          <% end %>
        </div>

        <label class="modal-backdrop" for="event-preference-modal"><%= t("views.events.preferences.close") %></label>
      </div>
    <% end %>
  </div>
</section>
