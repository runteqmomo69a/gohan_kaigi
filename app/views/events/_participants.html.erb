<section class="card bg-base-100/95 border border-[#d7cdbc] shadow-xl shadow-orange-200/20 overflow-hidden">
  <div class="card-body p-6 space-y-5">
    <div class="flex items-start justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
          <span class="material-symbols-outlined">groups</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-neutral-700"><%= t("views.events.participants.title") %></h2>
          <p class="text-sm text-base-content/60"><%= t("views.events.participants.count", count: participants.count) %></p>
        </div>
      </div>
    </div>

    <% if participants.any? %>
      <div class="rounded-3xl bg-amber-50/60 border border-amber-100 p-4">
        <div class="flex flex-wrap gap-3">
          <% participants.each do |participant| %>
            <div class="flex items-center gap-3 rounded-2xl bg-white/90 border border-amber-100 px-3 py-2 min-w-[140px]">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-orange-100 text-orange-700 font-bold">
                <%= participant.name.to_s.first %>
              </div>
              <div class="text-sm text-neutral-700 font-medium">
                <%= participant.name %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="rounded-2xl bg-stone-50 border border-stone-200 px-4 py-4 text-sm text-base-content/60">
        <%= t("views.events.participants.empty") %>
      </div>
    <% end %>
  </div>
</section>
