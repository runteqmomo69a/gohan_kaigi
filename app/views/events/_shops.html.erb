<div class="mt-8">
  <div class="card bg-base-100 shadow-md rounded-xl">
    <div class="card-body">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <h2 class="text-xl font-bold"><%= t("views.events.shops.title") %></h2>

        <div class="flex flex-wrap items-center gap-2">
          <%= link_to t("views.events.shops.sort_created"), event_path(event, sort: "created_at"), class: "btn btn-outline btn-sm" %>
          <%= link_to t("views.events.shops.sort_likes"), event_path(event, sort: "likes_count"), class: "btn btn-outline btn-sm" %>
          <%= link_to t("views.events.shops.new_shop"), new_event_shop_path(event), class: "btn btn-primary btn-sm" %>
        </div>
      </div>

      <% if shops.any? %>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <% shops.each do |shop| %>
            <div class="rounded-xl border border-base-300 bg-base-100 p-4 shadow-sm transition hover:shadow-md">
              <div class="flex items-start justify-between gap-3">
                <p class="text-lg font-semibold leading-snug"><%= shop.name %></p>
                <span class="shrink-0 text-sm font-medium text-gray-500">❤️ <%= shop.likes_count %></span>
              </div>

              <% if shop.url.present? %>
                <p class="mt-2 text-sm">
                  <a href="<%= shop.url %>" target="_blank" class="text-blue-500 underline">
                    <%= t("views.events.shops.shop_url") %>
                  </a>
                </p>
              <% end %>

              <% if shop.memo.present? %>
                <p class="mt-2 text-sm text-gray-600 line-clamp-3"><%= shop.memo %></p>
              <% end %>

              <p class="mt-3 text-xs text-gray-400">
                <%= t("views.events.shops.owner", name: shop.user.name) %>
              </p>

              <div class="mt-4">
                <% if current_user.likes.exists?(shop: shop) %>
                  <%= link_to t("views.events.shops.unlike"),
                    event_shop_like_path(event, shop),
                    data: { turbo_method: :delete },
                    class: "btn btn-outline btn-sm w-full" %>
                <% else %>
                  <%= link_to t("views.events.shops.like"),
                    event_shop_like_path(event, shop),
                    data: { turbo_method: :post },
                    class: "btn btn-primary btn-sm w-full" %>
                <% end %>
              </div>

              <% if shop.user == current_user %>
                <div class="mt-3 flex gap-2">
                  <%= link_to t("common.edit"),
                    edit_event_shop_path(event, shop),
                    class: "btn btn-outline btn-sm flex-1" %>

                  <%= link_to t("common.delete"),
                    event_shop_path(event, shop),
                    data: { turbo_method: :delete, turbo_confirm: t("views.events.shops.delete_confirm") },
                    class: "btn btn-error btn-sm flex-1" %>
                </div>
              <% end %>

              <details class="mt-3">
                <summary class="btn btn-outline btn-sm w-full"><%= t("views.events.shops.show_map") %></summary>

                <div class="mt-3 overflow-hidden rounded-lg border border-base-300">
                  <iframe
                    src="<%= shop.map_embed_url(event.place) %>"
                    width="100%"
                    height="220"
                    style="border:0;"
                    loading="lazy"
                    allowfullscreen>
                  </iframe>
                </div>

                <div class="mt-2 text-right">
                  <%= link_to t("views.events.shops.open_google_map"),
                    shop.map_link_url(event.place),
                    target: "_blank",
                    rel: "noopener",
                    class: "link link-primary text-sm" %>
                </div>
              </details>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-2 text-sm text-gray-500"><%= t("views.events.shops.empty") %></p>
      <% end %>
    </div>
  </div>
</div>
