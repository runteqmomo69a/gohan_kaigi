<section class="card bg-base-100/95 border border-[#d7cdbc] shadow-xl shadow-orange-200/20 overflow-hidden">
  <div class="card-body p-6 sm:p-7 space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-[#c45f3d]"><%= t("views.events.shops.section_label") %></p>
        <h2 class="mt-2 text-2xl sm:text-3xl font-black tracking-tight text-neutral-700"><%= t("views.events.shops.title") %></h2>
        <p class="mt-2 text-base-content/60"><%= t("views.events.shops.description") %></p>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <%= link_to t("views.events.shops.sort_created"), event_path(event, sort: "created_at"), class: "btn btn-outline rounded-full border-[#d7cdbc] text-base-content/70 hover:bg-amber-50" %>
        <%= link_to t("views.events.shops.sort_likes"), event_path(event, sort: "likes_count"), class: "btn btn-outline rounded-full border-[#d7cdbc] text-base-content/70 hover:bg-amber-50" %>
        <%= link_to t("views.events.shops.new_shop"), new_event_shop_path(event), class: "btn rounded-full bg-[#e3744b] text-white border-none hover:bg-[#cf643d] shadow-md shadow-orange-200/35" %>
      </div>
    </div>

    <% if shops.any? %>
      <div class="space-y-4">
        <% shops.each_with_index do |shop, index| %>
          <article class="group rounded-[2rem] border border-[#f3c8b8] bg-gradient-to-br from-white to-[#fff5f0] p-5 sm:p-6 shadow-sm transition hover:shadow-xl hover:shadow-orange-200/20">
            <div class="flex flex-col gap-5 xl:flex-row xl:items-stretch xl:justify-between">
              <div class="xl:w-[220px] 2xl:w-[240px] shrink-0">
                <div class="h-56 xl:h-full min-h-56 overflow-hidden rounded-[1.5rem] border border-[#f3c8b8] bg-gradient-to-br from-stone-100 via-[#f7f2ec] to-[#fff1eb] relative">
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.9),transparent_45%),radial-gradient(circle_at_bottom_right,rgba(251,146,60,0.16),transparent_40%)]"></div>
                  <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6">
                    <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/90 text-[#e3744b] shadow-sm">
                      <span class="material-symbols-outlined text-3xl">photo</span>
                    </div>
                    <p class="mt-4 text-sm font-semibold text-stone-700"><%= t("views.events.shops.image_placeholder_title") %></p>
                    <p class="mt-2 text-xs leading-relaxed text-base-content/60">
                      <%= t("views.events.shops.image_placeholder_body") %>
                    </p>
                  </div>
                </div>
              </div>

              <div class="flex-1 space-y-4">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                  <div class="space-y-2">
                    <div class="inline-flex items-center gap-2 rounded-full bg-[#fff1eb] px-3 py-1 text-xs font-bold tracking-widest uppercase text-[#c45f3d] border border-[#f3c8b8]">
                      <span class="material-symbols-outlined text-sm">storefront</span>
                      <%= t("views.events.shops.candidate_badge", number: index + 1) %>
                    </div>
                    <h3 class="text-2xl font-bold tracking-tight text-neutral-700"><%= shop.name %></h3>
                    <p class="text-sm text-base-content/50"><%= t("views.events.shops.owner", name: shop.user.name) %></p>
                  </div>

                  <div class="inline-flex items-center gap-2 rounded-2xl bg-white/90 border border-[#f3c8b8] px-4 py-3 text-sm font-semibold text-base-content/70 shrink-0">
                    <span class="material-symbols-outlined text-[#e3744b]">favorite</span>
                    <span><%= shop.likes_count %></span>
                  </div>
                </div>

                <% if shop.memo.present? %>
                  <div class="rounded-2xl bg-white/80 border border-[#f3c8b8] px-4 py-4">
                    <p class="text-xs font-bold tracking-widest uppercase text-base-content/50"><%= t("views.events.shops.memo_label") %></p>
                    <div class="mt-2 max-h-28 overflow-y-auto pr-2">
                      <p class="text-sm leading-relaxed text-base-content/70"><%= shop.memo %></p>
                    </div>
                  </div>
                <% end %>

                <div class="flex flex-wrap gap-3">
                  <% if shop.url.present? %>
                    <%= link_to t("views.events.shops.shop_url"),
                      shop.url,
                      target: "_blank",
                      rel: "noopener",
                      class: "btn btn-outline rounded-full border-[#d7cdbc] text-base-content/70 hover:bg-amber-50" %>
                  <% end %>

                  <% if current_user.likes.exists?(shop: shop) %>
                    <%= link_to t("views.events.shops.unlike"),
                      event_shop_like_path(event, shop),
                      data: { turbo_method: :delete },
                      class: "btn rounded-full bg-[#fff1eb] text-[#c45f3d] border border-[#f3c8b8] hover:bg-[#fde4d8]" %>
                  <% else %>
                    <%= link_to t("views.events.shops.like"),
                      event_shop_like_path(event, shop),
                      data: { turbo_method: :post },
                      class: "btn rounded-full bg-[#e3744b] text-white border-none hover:bg-[#cf643d] shadow-md shadow-orange-200/35" %>
                  <% end %>

                  <% if shop.user == current_user %>
                    <%= link_to t("common.edit"),
                      edit_event_shop_path(event, shop),
                      class: "btn btn-outline rounded-full border-[#d7cdbc] text-base-content/70 hover:bg-amber-50" %>

                    <%= link_to t("common.delete"),
                      event_shop_path(event, shop),
                      data: { turbo_method: :delete, turbo_confirm: t("views.events.shops.delete_confirm") },
                      class: "btn rounded-full bg-red-50 text-red-600 border border-red-100 hover:bg-red-100" %>
                  <% end %>
                </div>
              </div>

              <div class="xl:w-[280px] 2xl:w-[300px] shrink-0 space-y-3">
                <details class="rounded-3xl overflow-hidden border border-[#f3c8b8] bg-white/80">
                  <summary class="flex cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold text-neutral-700">
                    <span><%= t("views.events.shops.show_map") %></span>
                    <span class="material-symbols-outlined text-base text-[#e3744b]">expand_more</span>
                  </summary>

                  <div class="border-t border-[#f3c8b8] p-4">
                    <div class="overflow-hidden rounded-2xl border border-[#f3c8b8] bg-white">
                      <iframe
                        src="<%= shop.map_embed_url(event.place) %>"
                        width="100%"
                        height="220"
                        style="border:0;"
                        loading="lazy"
                        allowfullscreen>
                      </iframe>
                    </div>

                    <div class="mt-3 text-right">
                      <%= link_to t("views.events.shops.open_google_map"),
                        shop.map_link_url(event.place),
                        target: "_blank",
                        rel: "noopener",
                        class: "link link-hover text-sm text-[#c45f3d]" %>
                    </div>
                  </div>
                </details>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-2xl bg-stone-50 border border-stone-200 px-4 py-4 text-sm text-base-content/60">
        <%= t("views.events.shops.empty") %>
      </div>
    <% end %>
  </div>
</section>
