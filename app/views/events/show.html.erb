<div class="max-w-4xl mx-auto p-6">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @event.title %></h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= @event.event_date %>
        <% if @event.event_time.present? %>
          <span> <%= @event.event_time.strftime("%H:%M") %></span>
        <% end %>
        <% if @event.place.present? %>
          <span class="mx-2">•</span>
          <%= @event.place %>
        <% end %>
      </p>
    </div>

    <div class="flex items-center gap-2">
      <%= link_to "一覧へ戻る", events_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to "編集", edit_event_path(@event), class: "btn btn-outline btn-sm" %>
      <%= link_to "削除",
                  event_path(@event),
                  data: { turbo_method: :delete, turbo_confirm: "このイベントを削除します。よろしいですか？" },
                  class: "btn btn-error btn-sm" %>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body space-y-4">
      <div>
        <p class="text-sm text-gray-500">日時</p>
        <p class="text-base">
          <%= @event.event_date %>
          <% if @event.event_time.present? %>
            <span> <%= @event.event_time.strftime("%H:%M") %></span>
          <% else %>
            <span class="text-gray-400">（時間未設定）</span>
          <% end %>
        </p>
      </div>

      <div>
        <p class="text-sm text-gray-500">場所</p>
        <p class="text-base">
          <%= @event.place.presence || "未設定" %>
        </p>
      </div>

      <div>
        <p class="text-sm text-gray-500">メモ</p>
        <p class="text-base whitespace-pre-wrap">
          <%= @event.note.presence || "メモはありません" %>
        </p>
      </div>

      <div>
        <p class="text-sm text-gray-500">作成者</p>
        <p class="text-base"><%= @event.user.name %></p>
      </div>

      <div class="mt-4 rounded-lg border border-base-300 p-4 bg-base-100" data-controller="clipboard">
        <p class="text-sm text-gray-500 mb-2">共有用URL</p>

        <div class="flex flex-col gap-2 sm:flex-row">
          <input
            type="text"
            value="<%= join_event_url(@event.unique_url) %>"
            readonly
            class="input input-bordered w-full text-sm"
            data-clipboard-target="source"
          >

          <button
            type="button"
            class="btn btn-outline btn-sm shrink-0"
            data-action="click->clipboard#copy"
          >
            コピー
          </button>
        </div>

        <p class="text-xs text-success mt-2 hidden" data-clipboard-target="message">
          URLをコピーしました
        </p>
      </div>
    </div>
  </div>

  <div class="mt-6">
    <% if @participating %>
      <button class="btn btn-disabled">参加済み</button>
    <% else %>
      <label for="join-event-modal" class="btn btn-primary">
        このイベントに参加する
      </label>

      <input type="checkbox" id="join-event-modal" class="modal-toggle" />

      <div class="modal" role="dialog">
        <div class="modal-box max-w-lg">
          <h3 class="text-lg font-bold">このイベントに参加しますか？</h3>

          <p class="py-4 text-sm text-base-content/70 leading-7">
            参加すると
            <br>
            ・お店候補を見られます
            <br>
            ・お店を追加できます
            <br>
            ・気になるお店にいいねできます
          </p>

          <div class="modal-action">
            <%= button_to "このイベントに参加する",
                event_event_participants_path(@event),
                method: :post,
                class: "btn btn-primary" %>

            <label for="join-event-modal" class="btn btn-ghost">
              キャンセル
            </label>
          </div>
        </div>

        <label class="modal-backdrop" for="join-event-modal">Close</label>
      </div>
    <% end %>
  </div>

  <div class="mt-8">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-lg">参加者</h2>

        <% if @participants.any? %>
          <ul class="mt-2 space-y-2">
            <% @participants.each do |participant| %>
              <li class="flex items-center gap-2">
                <span class="badge badge-outline">参加中</span>
                <span><%= participant.name %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500 mt-2">まだ参加者はいません</p>
        <% end %>
      </div>
    </div>
  </div>

    <div class="mt-8">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <h2 class="card-title text-lg">希望条件</h2>

          <% if @participating %>
            <label for="event-preference-modal" class="btn btn-primary btn-sm">
              希望条件を入力
            </label>
          <% end %>
        </div>

        <% if @event_preferences.any? %>
          <ul class="mt-4 space-y-3">
            <% @event_preferences.each do |event_preference| %>
              <li class="border rounded p-3 space-y-2">
                
                <% if event_preference.user_id == current_user.id %>
                  <p class="text-xs text-primary font-bold">あなたの投稿</p>
                <% end %>
                <div>
                  <p class="text-sm text-gray-500">苦手なもの</p>
                  <p><%= event_preference.dislike_foods.presence || "特にありません" %></p>
                </div>

                <div>
                  <p class="text-sm text-gray-500">予算</p>
                  <p><%= event_preference.budget_label %></p>
                </div>

                <div>
                  <p class="text-sm text-gray-500">自由記述</p>
                  <p class="whitespace-pre-wrap"><%= event_preference.content.presence || "特にありません" %></p>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500 mt-2">まだ投稿がありません</p>
        <% end %>

        <% if @participating %>
          <input type="checkbox" id="event-preference-modal" class="modal-toggle" />

          <div class="modal" role="dialog">
            <div class="modal-box max-w-lg">
              <h3 class="text-lg font-bold">希望条件を入力</h3>

              <%= form_with model: @event_preference,
                            url: event_event_preferences_path(@event),
                            method: :post,
                            local: true do |f| %>
                <div class="mt-4 space-y-4">
                  <div class="form-control">
                    <%= f.label :dislike_foods, "苦手なもの（アレルギー・避けたいものなど）", class: "label" %>
                    <%= f.text_area :dislike_foods, class: "textarea textarea-bordered w-full", rows: 3 %>
                  </div>

                  <div class="form-control">
                    <%= f.label :budget, "予算(目安）", class: "label" %>
                    <%= f.select :budget,
                      [
                        ["未選択", nil],
                        ["〜999円", 1],
                        ["1000〜1999円", 2],
                        ["2000〜2999円", 3],
                        ["3000〜3999円", 4],
                        ["4000円以上", 5]
                      ],
                      {},
                      class: "select select-bordered w-full" %>
                  </div>

                  <div class="form-control">
                    <%= f.label :content, "その他の希望（任意）", class: "label" %>
                    <%= f.text_area :content, class: "textarea textarea-bordered w-full", rows: 4 %>
                  </div>

                  <div class="modal-action">
                    <% if @event_preference.persisted? %>
                      <%= link_to "削除する",
                        event_event_preference_path(@event, @event_preference),
                        data: { turbo_method: :delete, turbo_confirm: "希望条件を削除しますか？" },
                        class: "btn btn-error" %>
                    <% end %>

                    <%= f.submit "保存する", class: "btn btn-primary" %>
                    <label for="event-preference-modal" class="btn btn-ghost">キャンセル</label>
                  </div>
            <% end %>
          </div>

          <label class="modal-backdrop" for="event-preference-modal">Close</label>
        </div>
      <% end %>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-lg">人気ランキング TOP3</h2>

      <% if @top_shops.any? %>
        <ul class="mt-4 space-y-2">
          <% @top_shops.each_with_index do |shop, index| %>
            <li class="flex items-center gap-2">
              <% case index %>
              <% when 0 %>
                <span class="badge badge-warning">1位</span>
              <% when 1 %>
                <span class="badge badge-neutral">2位</span>
              <% when 2 %>
                <span class="badge badge-accent">3位</span>
              <% end %>

              <span><%= shop.name %></span>
              <span class="text-sm text-gray-500">（<%= shop.likes_count %>いいね）</span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-500 mt-2">まだランキングはありません</p>
      <% end %>
    </div>
  </div>
</div>

  <div class="mt-8">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <h2 class="card-title text-lg">お店候補</h2>

          <div class="flex items-center gap-2">
            <%= link_to "登録順", event_path(@event, sort: "created_at"), class: "btn btn-outline btn-sm" %>
            <%= link_to "いいね順", event_path(@event, sort: "likes_count"), class: "btn btn-outline btn-sm" %>
            <%= link_to "お店候補を登録", new_event_shop_path(@event), class: "btn btn-primary btn-sm" %>
          </div>
        </div>

        <% if @shops.any? %>
          <ul class="mt-4 space-y-3">
            <% @shops.each do |shop| %>
              <li class="border rounded p-3">
                <p class="font-semibold"><%= shop.name %></p>

                <% if shop.url.present? %>
                  <p class="text-sm">
                    <a href="<%= shop.url %>" target="_blank" class="text-blue-500 underline">
                      お店のURL
                    </a>
                  </p>
                <% end %>

                <% if shop.memo.present? %>
                  <p class="text-sm text-gray-600 mt-1"><%= shop.memo %></p>
                <% end %>

                <p class="text-xs text-gray-400 mt-2">
                  登録者：<%= shop.user.name %>
                </p>

                <p class="text-sm text-gray-500 mt-1">
                  👍 <%= shop.likes_count %>
                </p>

                <% if shop.user == current_user %>
                  <div class="mt-3 flex gap-2">
                    <%= link_to "編集",
                      edit_event_shop_path(@event, shop),
                      class: "btn btn-outline btn-sm" %>

                    <%= link_to "削除",
                      event_shop_path(@event, shop),
                      data: { turbo_method: :delete, turbo_confirm: "このお店候補を削除します。よろしいですか？" },
                      class: "btn btn-error btn-sm" %>
                  </div>
                <% end %>
                <div class="mt-2">
                  <% if current_user.likes.exists?(shop: shop) %>
                    <%= link_to "いいね解除",
                      event_shop_like_path(@event, shop),
                      data: { turbo_method: :delete },
                      class: "btn btn-outline btn-sm" %>
                  <% else %>
                    <%= link_to "いいね",
                      event_shop_like_path(@event, shop),
                      data: { turbo_method: :post },
                      class: "btn btn-primary btn-sm" %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500 mt-2">まだお店候補はありません</p>
        <% end %>
      </div>
    </div>
  </div>
</div>