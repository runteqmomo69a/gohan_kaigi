<div class="max-w-4xl mx-auto p-6">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @event.title %></h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= @event.event_date %>
        <% if @event.event_time.present? %>
          <span> <%= @event.event_time.strftime("%H:%M") %></span>
        <% end %>
        <% if @event.place.present? %>
          <span class="mx-2">•</span>
          <%= @event.place %>
        <% end %>
      </p>
    </div>

    <div class="flex items-center gap-2">
      <%= link_to "一覧へ戻る", events_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to "編集", edit_event_path(@event), class: "btn btn-outline btn-sm" %>
      <%= link_to "削除",
                  event_path(@event),
                  data: { turbo_method: :delete, turbo_confirm: "このイベントを削除します。よろしいですか？" },
                  class: "btn btn-error btn-sm" %>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body space-y-4">
      <div>
        <p class="text-sm text-gray-500">日時</p>
        <p class="text-base">
          <%= @event.event_date %>
          <% if @event.event_time.present? %>
            <span> <%= @event.event_time.strftime("%H:%M") %></span>
          <% else %>
            <span class="text-gray-400">（時間未設定）</span>
          <% end %>
        </p>
      </div>

      <div>
        <p class="text-sm text-gray-500">場所</p>
        <p class="text-base">
          <%= @event.place.presence || "未設定" %>
        </p>
      </div>

      <div>
        <p class="text-sm text-gray-500">メモ</p>
        <p class="text-base whitespace-pre-wrap">
          <%= @event.note.presence || "メモはありません" %>
        </p>
      </div>

      <div>
        <p class="text-sm text-gray-500">作成者</p>
        <p class="text-base"><%= @event.user.name %></p>
      </div>

      <div class="mt-4 rounded-lg border border-base-300 p-4 bg-base-100" data-controller="clipboard">
        <p class="text-sm text-gray-500 mb-2">共有用URL</p>

        <div class="flex flex-col gap-2 sm:flex-row">
          <input
            type="text"
            value="<%= join_event_url(@event.unique_url) %>"
            readonly
            class="input input-bordered w-full text-sm"
            data-clipboard-target="source"
          >

          <button
            type="button"
            class="btn btn-outline btn-sm shrink-0"
            data-action="click->clipboard#copy"
          >
            コピー
          </button>
        </div>

        <p class="text-xs text-success mt-2 hidden" data-clipboard-target="message">
          URLをコピーしました
        </p>
      </div>
    </div>
  </div>

  <div class="mt-6">
    <% if @participating %>
      <button class="btn btn-disabled">参加済み</button>
    <% else %>
      <label for="join-event-modal" class="btn btn-primary">
        このイベントに参加する
      </label>

      <input type="checkbox" id="join-event-modal" class="modal-toggle" />

      <div class="modal" role="dialog">
        <div class="modal-box max-w-lg">
          <h3 class="text-lg font-bold">このイベントに参加しますか？</h3>

          <p class="py-4 text-sm text-base-content/70 leading-7">
            参加すると
            <br>
            ・お店候補を見られます
            <br>
            ・お店を追加できます
            <br>
            ・気になるお店にいいねできます
          </p>

          <div class="modal-action">
            <%= button_to "このイベントに参加する",
                event_event_participants_path(@event),
                method: :post,
                class: "btn btn-primary" %>

            <label for="join-event-modal" class="btn btn-ghost">
              キャンセル
            </label>
          </div>
        </div>

        <label class="modal-backdrop" for="join-event-modal">Close</label>
      </div>
    <% end %>
  </div>

  <div class="mt-8">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-lg">参加者</h2>

        <% if @participants.any? %>
          <ul class="mt-2 space-y-2">
            <% @participants.each do |participant| %>
              <li class="flex items-center gap-2">
                <span class="badge badge-outline">参加中</span>
                <span><%= participant.name %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500 mt-2">まだ参加者はいません</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <h2 class="card-title text-lg">お店候補</h2>
          <%= link_to "お店候補を登録", new_event_shop_path(@event), class: "btn btn-primary btn-sm" %>
        </div>

        <% if @shops.any? %>
          <ul class="mt-4 space-y-3">
            <% @shops.each do |shop| %>
              <li class="border rounded p-3">
                <p class="font-semibold"><%= shop.name %></p>

                <% if shop.url.present? %>
                  <p class="text-sm">
                    <a href="<%= shop.url %>" target="_blank" class="text-blue-500 underline">
                      お店のURL
                    </a>
                  </p>
                <% end %>

                <% if shop.memo.present? %>
                  <p class="text-sm text-gray-600 mt-1"><%= shop.memo %></p>
                <% end %>

                <p class="text-xs text-gray-400 mt-2">
                  登録者：<%= shop.user.name %>
                </p>
                
                <div class="mt-3 flex gap-2">
                  <%= link_to "編集",
                    edit_event_shop_path(@event, shop),
                    class: "btn btn-outline btn-sm" %>

                  <%= link_to "削除",
                    event_shop_path(@event, shop),
                    data: { turbo_method: :delete, turbo_confirm: "このお店候補を削除します。よろしいですか？" },
                    class: "btn btn-error btn-sm" %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500 mt-2">まだお店候補はありません</p>
        <% end %>
      </div>
    </div>
  </div>
</div>