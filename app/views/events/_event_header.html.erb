<div class="space-y-6">

  <!-- タイトル + 操作 -->
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <h1 class="text-3xl font-bold leading-tight">
      <%= event.title %>
    </h1>

    <div class="flex items-center gap-2 flex-wrap">
      <%= link_to t("views.events.show.back_to_index"), events_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to t("common.edit"), edit_event_path(event), class: "btn btn-outline btn-sm" %>
      <%= link_to t("common.delete"),
                  event_path(event),
                  data: { turbo_method: :delete, turbo_confirm: t("views.events.show.delete_confirm") },
                  class: "btn btn-error btn-sm" %>
    </div>
  </div>

  <!-- 基本情報 -->
  <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-gray-600">

    <div class="flex items-center gap-1">
      <span>📅</span>
      <span class="font-medium text-base-content">
        <%= event.event_date %>
      </span>
    </div>

    <div class="flex items-center gap-1">
      <span>🕒</span>
      <span class="font-medium text-base-content">
        <%= event.event_time.present? ? event.event_time.strftime("%H:%M") : t("views.events.show.time_unset") %>
      </span>
    </div>

    <div class="flex items-center gap-1">
      <span>📍</span>
      <span class="font-medium text-base-content">
        <%= event.place.presence || t("views.events.show.place_unset") %>
      </span>
    </div>

    <div class="flex items-center gap-1">
      <span>👤</span>
      <span class="font-medium text-base-content">
        <%= event.user.name %>
      </span>
    </div>

  </div>

  <!-- メモ -->
  <% if event.note.present? %>
    <div class="rounded-xl border border-base-300 bg-base-100 p-4 space-y-2">
      <div class="flex items-center gap-2 text-sm text-gray-500">
        <span>📝</span>
        <span><%= t("views.events.show.note") %></span>
      </div>

      <p class="text-base leading-relaxed">
        <%= event.note %>
      </p>
    </div>
  <% end %>

  <!-- 参加ボタン -->
  <div>
    <% if participating %>
      <div class="inline-flex items-center gap-2 rounded-full bg-success/10 px-4 py-2 text-sm font-medium text-success">
        <span>✓</span>
        <span><%= t("views.events.show.joined") %></span>
      </div>
    <% else %>
      <label for="join-event-modal" class="btn btn-primary">
        <%= t("views.events.show.join_event") %>
      </label>

      <input type="checkbox" id="join-event-modal" class="modal-toggle" />
      <div class="modal" role="dialog">
        <div class="modal-box">
          <h3 class="text-lg font-bold"><%= t("views.events.show.join_modal_title") %></h3>
          <p class="pt-3"><%= t("views.events.show.join_modal_body") %></p>
          <div class="py-3 text-sm text-base-content/70 leading-7">
            <p><%= t("views.events.show.join_modal_features_intro") %></p>
            <ul class="list-disc pl-5 mt-1">
              <li><%= t("views.events.show.join_modal_feature_1") %></li>
              <li><%= t("views.events.show.join_modal_feature_2") %></li>
              <li><%= t("views.events.show.join_modal_feature_3") %></li>
            </ul>
          </div>

          <%= form_with url: event_event_participants_path(event), method: :post, local: true do |f| %>
            <div class="modal-action">
              <%= f.submit t("views.events.show.join_modal_submit"), class: "btn btn-primary" %>
              <label for="join-event-modal" class="btn btn-ghost"><%= t("common.cancel") %></label>
            </div>
          <% end %>
        </div>

        <label class="modal-backdrop" for="join-event-modal"><%= t("common.cancel") %></label>
      </div>
    <% end %>
  </div>

  <!-- URL -->
  <div class="rounded-xl border border-base-300 bg-base-100 p-4"
       data-controller="clipboard"
       data-clipboard-error-message-value="<%= t('views.events.show.copy_failed') %>">
    <p class="text-sm text-gray-500 mb-2"><%= t("views.events.show.share_url") %></p>

    <div class="flex flex-col gap-2 sm:flex-row">
      <input
        type="text"
        value="<%= join_event_url(event.unique_url) %>"
        readonly
        class="input input-bordered w-full text-sm"
        data-clipboard-target="source"
      >

      <button
        type="button"
        class="btn btn-outline btn-sm shrink-0"
        data-action="click->clipboard#copy"
      >
        <%= t("views.events.show.copy") %>
      </button>
    </div>

    <p class="text-xs text-success mt-2 hidden" data-clipboard-target="message">
      <%= t("views.events.show.copied") %>
    </p>
  </div>

</div>
