<div class="bg-gradient-to-b from-[#fbf6ef] via-[#f8f1e7] to-[#f5ede2]">
  <div class="max-w-6xl mx-auto px-4 py-8 sm:py-12 space-y-14 sm:space-y-20">

    <section class="relative overflow-hidden rounded-3xl border border-[#d7cdbc] bg-gradient-to-br from-[#f6ede3] via-[#fbf5ed] to-[#f4ebdf] px-6 py-16 sm:px-10 sm:py-24 shadow-lg shadow-stone-200/20">
      <div class="absolute right-0 top-0 h-52 w-52 -translate-y-1/3 translate-x-1/4 rounded-full bg-[#d8b89c]/18 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-48 w-48 -translate-x-1/3 translate-y-1/3 rounded-full bg-[#e7d6c1]/22 blur-3xl"></div>
      <div class="absolute left-2 top-12 hidden text-[#e0d1be]/70 pointer-events-none z-0 xl:left-8 lg:block" aria-hidden="true">
        <span class="material-symbols-outlined text-[72px]">restaurant</span>
      </div>
      <div class="absolute right-2 bottom-12 hidden text-[#e0d1be]/70 pointer-events-none z-0 xl:right-8 lg:block" aria-hidden="true">
        <span class="material-symbols-outlined text-[72px]">lunch_dining</span>
      </div>

      <div class="relative z-10 max-w-3xl mx-auto text-center">
        <p class="inline-flex items-center rounded-full border border-[#d7cdbc] bg-[#f4ede3] px-5 py-2 text-sm font-bold tracking-widest text-[#927765] mb-5">
          <%= t("views.static_pages.top.hero.badge") %>
        </p>

        <h1 class="brand-title text-[2.45rem] sm:text-[3.7rem] lg:text-[4.5rem] font-black tracking-tight leading-[1.08] text-neutral-700">
          <span class="sm:hidden"><%= t("views.static_pages.top.hero.title_line1_mobile") %></span>
          <span class="hidden sm:inline"><%= t("views.static_pages.top.hero.title_line1") %></span><br>
          <span class="text-[#e3744b]"><%= t("views.static_pages.top.hero.title_highlight") %></span>
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-base sm:text-lg text-[#6f5f52] leading-relaxed">
          <%= t("views.static_pages.top.hero.description_line1") %><br class="hidden sm:block">
          <%= t("views.static_pages.top.hero.description_line2") %>
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
          <%= link_to t("views.static_pages.top.hero.cta_signup"), new_user_registration_path, class: "btn btn-lg rounded-full px-8 bg-[#e3744b] border-none text-white hover:bg-[#cf643d]" %>
          <%= link_to t("views.static_pages.top.hero.cta_login"), new_user_session_path, class: "btn btn-outline btn-lg rounded-full px-8 border-[#d7cdbc] text-[#7a6757] hover:bg-[#f8f0e7]" %>
        </div>
      </div>
    </section>

    <section class="rounded-3xl border border-[#d7cdbc] bg-[#fffaf4]/90 p-6 shadow-sm sm:p-10">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-bold tracking-widest text-[#b47a61] uppercase">
          <%= t("views.static_pages.top.pains.section_label") %>
        </p>
        <h2 class="brand-title mt-2 text-3xl sm:text-4xl font-black tracking-tight text-neutral-700">
          <%= t("views.static_pages.top.pains.title") %>
        </h2>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
        <article class="rounded-3xl border border-[#d7cdbc] bg-[#fffdf9] p-5 shadow-md shadow-stone-200/10">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#fff1eb] text-[#e3744b]">
            <span class="material-symbols-outlined"><%= t("views.static_pages.top.pains.item1_icon") %></span>
          </div>
          <h3 class="mt-4 text-xl font-bold leading-snug text-neutral-700"><%= t("views.static_pages.top.pains.item1_title") %></h3>
          <p class="mt-2 text-sm leading-relaxed text-[#6f5f52]"><%= t("views.static_pages.top.pains.item1_desc") %></p>
        </article>

        <article class="rounded-3xl border border-[#d7cdbc] bg-[#fffdf9] p-5 shadow-md shadow-stone-200/10">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#fff6dc] text-[#b07a10]">
            <span class="material-symbols-outlined"><%= t("views.static_pages.top.pains.item2_icon") %></span>
          </div>
          <h3 class="mt-4 text-xl font-bold leading-snug text-neutral-700"><%= t("views.static_pages.top.pains.item2_title") %></h3>
          <p class="mt-2 text-sm leading-relaxed text-[#6f5f52]"><%= t("views.static_pages.top.pains.item2_desc") %></p>
        </article>

        <article class="rounded-3xl border border-[#d7cdbc] bg-[#fffdf9] p-5 shadow-md shadow-stone-200/10">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#eef5ec] text-[#5f7d4e]">
            <span class="material-symbols-outlined"><%= t("views.static_pages.top.pains.item3_icon") %></span>
          </div>
          <h3 class="mt-4 text-xl font-bold leading-snug text-neutral-700"><%= t("views.static_pages.top.pains.item3_title") %></h3>
          <p class="mt-2 text-sm leading-relaxed text-[#6f5f52]"><%= t("views.static_pages.top.pains.item3_desc") %></p>
        </article>

        <article class="rounded-3xl border border-[#d7cdbc] bg-[#fffdf9] p-5 shadow-md shadow-stone-200/10">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#edf3f2] text-[#52736b]">
            <span class="material-symbols-outlined"><%= t("views.static_pages.top.pains.item4_icon") %></span>
          </div>
          <h3 class="mt-4 text-xl font-bold leading-snug text-neutral-700"><%= t("views.static_pages.top.pains.item4_title") %></h3>
          <p class="mt-2 text-sm leading-relaxed text-[#6f5f52]"><%= t("views.static_pages.top.pains.item4_desc") %></p>
        </article>
      </div>

      <p class="mx-auto mt-6 max-w-3xl text-center text-sm sm:text-base leading-relaxed text-[#7a6757]">
        <%= t("views.static_pages.top.pains.closing") %>
      </p>
    </section>

    <section>
      <div class="mb-8 sm:mb-10">
        <p class="text-xs font-bold tracking-widest text-[#b47a61] uppercase">
          <%= t("views.static_pages.top.features.section_label") %>
        </p>
        <h2 class="brand-title mt-2 text-3xl sm:text-4xl font-black tracking-tight text-neutral-700">
          <%= t("views.static_pages.top.features.title") %>
        </h2>
        <p class="mt-3 max-w-2xl text-[#6f5f52]">
          <%= t("views.static_pages.top.features.lead") %>
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 sm:gap-6">
        <article class="md:col-span-7 card bg-[#fffdf9] shadow-md shadow-stone-200/10 border border-[#d7cdbc]">
          <div class="card-body p-6 sm:p-8">
            <p class="text-2xl">🧩</p>
            <h3 class="text-2xl font-bold text-neutral-700"><%= t("views.static_pages.top.features.item1_title") %></h3>
            <p class="text-[#6f5f52]"><%= t("views.static_pages.top.features.item1_desc") %></p>
          </div>
        </article>

        <article class="md:col-span-5 card bg-[#fcf7f0] shadow-md shadow-stone-200/10 border border-[#d7cdbc]">
          <div class="card-body p-6 sm:p-8">
            <p class="text-2xl">❤️</p>
            <h3 class="text-2xl font-bold text-neutral-700"><%= t("views.static_pages.top.features.item2_title") %></h3>
            <p class="text-[#6f5f52]"><%= t("views.static_pages.top.features.item2_desc") %></p>
          </div>
        </article>

        <article class="md:col-span-5 card bg-[#fbf6ef] shadow-md shadow-stone-200/10 border border-[#d7cdbc]">
          <div class="card-body p-6 sm:p-8">
            <p class="text-2xl">🤫</p>
            <h3 class="text-2xl font-bold text-neutral-700"><%= t("views.static_pages.top.features.item3_title") %></h3>
            <p class="text-[#6f5f52]"><%= t("views.static_pages.top.features.item3_desc") %></p>
          </div>
        </article>

        <article class="md:col-span-7 card bg-[#fffdf9] shadow-md shadow-stone-200/10 border border-[#d7cdbc]">
          <div class="card-body p-6 sm:p-8">
            <p class="text-2xl">📚</p>
            <h3 class="text-2xl font-bold text-neutral-700"><%= t("views.static_pages.top.features.item4_title") %></h3>
            <p class="text-[#6f5f52]"><%= t("views.static_pages.top.features.item4_desc") %></p>
          </div>
        </article>
      </div>
    </section>

    <section class="rounded-3xl border border-[#d7cdbc] bg-[#f5ede2]/90 p-6 sm:p-10 shadow-sm">
      <p class="text-xs font-bold tracking-widest text-[#b47a61] uppercase text-center">
        <%= t("views.static_pages.top.how_to_use.section_label") %>
      </p>
      <h2 class="brand-title mt-2 text-center text-3xl sm:text-4xl font-black tracking-tight text-neutral-700">
        <%= t("views.static_pages.top.how_to_use.title") %>
      </h2>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
        <article class="card border border-[#d7cdbc] bg-[#fffdf9] shadow-md shadow-stone-200/10">
          <div class="card-body">
            <span class="inline-flex w-fit rounded-full bg-[#fff1eb] px-3 py-1 text-sm font-bold text-[#e3744b]"><%= t("views.static_pages.top.how_to_use.step1_badge") %></span>
            <h3 class="text-xl font-bold mt-2 text-neutral-700"><%= t("views.static_pages.top.how_to_use.step1_title") %></h3>
            <p class="text-[#6f5f52]"><%= t("views.static_pages.top.how_to_use.step1_desc") %></p>
          </div>
        </article>

        <article class="card border border-[#d7cdbc] bg-[#fffdf9] shadow-md shadow-stone-200/10">
          <div class="card-body">
            <span class="inline-flex w-fit rounded-full bg-[#fff1eb] px-3 py-1 text-sm font-bold text-[#e3744b]"><%= t("views.static_pages.top.how_to_use.step2_badge") %></span>
            <h3 class="text-xl font-bold mt-2 text-neutral-700"><%= t("views.static_pages.top.how_to_use.step2_title") %></h3>
            <p class="text-[#6f5f52]"><%= t("views.static_pages.top.how_to_use.step2_desc") %></p>
          </div>
        </article>

        <article class="card border border-[#d7cdbc] bg-[#fffdf9] shadow-md shadow-stone-200/10">
          <div class="card-body">
            <span class="inline-flex w-fit rounded-full bg-[#fff1eb] px-3 py-1 text-sm font-bold text-[#e3744b]"><%= t("views.static_pages.top.how_to_use.step3_badge") %></span>
            <h3 class="text-xl font-bold mt-2 text-neutral-700"><%= t("views.static_pages.top.how_to_use.step3_title") %></h3>
            <p class="text-[#6f5f52]"><%= t("views.static_pages.top.how_to_use.step3_desc") %></p>
          </div>
        </article>
      </div>
    </section>

    <section class="relative overflow-hidden rounded-3xl border border-[#d7cdbc] bg-[#e3744b] p-8 text-center text-white shadow-lg shadow-stone-200/20 sm:p-12">
      <div class="absolute -left-6 -bottom-8 hidden text-[#e3b49b]/35 pointer-events-none z-0 lg:block" aria-hidden="true">
        <span class="material-symbols-outlined text-[180px]">bakery_dining</span>
      </div>
      <div class="absolute -right-2 top-0 hidden text-[#f0cfbb]/45 pointer-events-none z-0 lg:block" aria-hidden="true">
        <span class="material-symbols-outlined text-[180px]">local_pizza</span>
      </div>

      <div class="relative z-10">
        <h2 class="brand-title text-3xl sm:text-5xl font-black leading-tight">
          <%= t("views.static_pages.top.final_cta.title") %>
        </h2>
        <p class="mt-4 text-white/90 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          <%= t("views.static_pages.top.final_cta.description_line1") %><br class="hidden sm:block">
          <%= t("views.static_pages.top.final_cta.description_line2") %>
        </p>
        <div class="mt-8">
          <%= link_to t("views.static_pages.top.final_cta.button"), new_user_registration_path, class: "btn btn-lg rounded-full px-10 bg-white text-[#b56e50] border-none hover:bg-[#fff7ef]" %>
        </div>
      </div>
    </section>

  </div>
</div>
