<div class="bg-base-200">
  <div class="max-w-5xl mx-auto px-4 py-10 sm:py-14">

    <!-- Hero -->
    <section class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <div class="flex flex-col gap-4">
          <div>
            <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
              <%= t("views.static_pages.top.hero.title") %>
            </h1>

            <h2 class="mt-4 text-xl sm:text-2xl font-semibold">
              <%= t("views.static_pages.top.hero.subtitle") %>
            </h2>

            <p class="mt-3 text-base sm:text-lg text-base-content/70">
              <%= t("views.static_pages.top.hero.description_line1") %><br class="hidden sm:block">
              <%= t("views.static_pages.top.hero.description_line2") %>
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <%= link_to t("views.static_pages.top.hero.cta_signup"), new_user_registration_path, class: "btn btn-primary" %>
            <%= link_to t("views.devise.shared.links.log_in"), new_user_session_path, class: "btn btn-outline" %>
          </div>

          <div class="divider my-2"></div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div class="rounded-box bg-base-200 p-4">
              <p class="font-semibold"><%= t("views.static_pages.top.hero.feature1_title") %></p>
              <p class="mt-1 text-sm text-base-content/70"><%= t("views.static_pages.top.hero.feature1_desc") %></p>
            </div>
            <div class="rounded-box bg-base-200 p-4">
              <p class="font-semibold"><%= t("views.static_pages.top.hero.feature2_title") %></p>
              <p class="mt-1 text-sm text-base-content/70"><%= t("views.static_pages.top.hero.feature2_desc") %></p>
            </div>
            <div class="rounded-box bg-base-200 p-4">
              <p class="font-semibold"><%= t("views.static_pages.top.hero.feature3_title") %></p>
              <p class="mt-1 text-sm text-base-content/70"><%= t("views.static_pages.top.hero.feature3_desc") %></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Steps -->
    <section class="mt-10">
      <h2 class="text-xl sm:text-2xl font-bold"><%= t("views.static_pages.top.steps.title") %></h2>
      <p class="mt-2 text-base-content/70">
        <%= t("views.static_pages.top.steps.description") %>
      </p>

      <div class="mt-5 grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <div class="flex items-center gap-2">
              <span class="badge badge-primary"><%= t("views.static_pages.top.steps.badge_1") %></span>
              <p class="font-bold"><%= t("views.static_pages.top.steps.step1_title") %></p>
            </div>
            <p class="mt-2 text-sm text-base-content/70">
              <%= t("views.static_pages.top.steps.step1_desc") %>
            </p>
          </div>
        </div>

        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <div class="flex items-center gap-2">
              <span class="badge badge-primary"><%= t("views.static_pages.top.steps.badge_2") %></span>
              <p class="font-bold"><%= t("views.static_pages.top.steps.step2_title") %></p>
            </div>
            <p class="mt-2 text-sm text-base-content/70">
              <%= t("views.static_pages.top.steps.step2_desc") %>
            </p>
          </div>
        </div>

        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <div class="flex items-center gap-2">
              <span class="badge badge-primary"><%= t("views.static_pages.top.steps.badge_3") %></span>
              <p class="font-bold"><%= t("views.static_pages.top.steps.step3_title") %></p>
            </div>
            <p class="mt-2 text-sm text-base-content/70">
              <%= t("views.static_pages.top.steps.step3_desc") %>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="mt-10">
      <div class="card bg-base-100 shadow">
        <div class="card-body">
          <h2 class="text-xl sm:text-2xl font-bold"><%= t("views.static_pages.top.benefits.title") %></h2>

          <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex gap-3">
              <div class="text-2xl">🍽️</div>
              <div>
                <p class="font-semibold"><%= t("views.static_pages.top.benefits.item1_title") %></p>
                <p class="text-sm text-base-content/70">
                  <%= t("views.static_pages.top.benefits.item1_desc") %>
                </p>
              </div>
            </div>

            <div class="flex gap-3">
              <div class="text-2xl">👀</div>
              <div>
                <p class="font-semibold"><%= t("views.static_pages.top.benefits.item2_title") %></p>
                <p class="text-sm text-base-content/70">
                  <%= t("views.static_pages.top.benefits.item2_desc") %>
                </p>
              </div>
            </div>

            <div class="flex gap-3">
              <div class="text-2xl">🧭</div>
              <div>
                <p class="font-semibold"><%= t("views.static_pages.top.benefits.item3_title") %></p>
                <p class="text-sm text-base-content/70">
                  <%= t("views.static_pages.top.benefits.item3_desc") %>
                </p>
              </div>
            </div>

            <div class="flex gap-3">
              <div class="text-2xl">⚡</div>
              <div>
                <p class="font-semibold"><%= t("views.static_pages.top.benefits.item4_title") %></p>
                <p class="text-sm text-base-content/70">
                  <%= t("views.static_pages.top.benefits.item4_desc") %>
                </p>
              </div>
            </div>
          </div>

          <div class="divider my-6"></div>

          <div class="flex flex-col sm:flex-row gap-3">
            <%= link_to t("views.static_pages.top.benefits.cta_signup"), new_user_registration_path, class: "btn btn-primary" %>
            <%= link_to t("views.static_pages.top.benefits.cta_login"), new_user_session_path, class: "btn btn-outline" %>
          </div>
        </div>
      </div>
    </section>

  </div>
</div>
