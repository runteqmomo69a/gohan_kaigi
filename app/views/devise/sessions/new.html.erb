<div class="min-h-[calc(100vh-64px)] flex items-center justify-center px-4 py-10">
  <div class="card w-full max-w-md bg-base-100 shadow">
    <div class="card-body">
      <h1 class="text-2xl font-bold"><%= t("views.devise.sessions.new.title") %></h1>
      <p class="text-sm text-gray-500"><%= t("views.devise.sessions.new.description") %></p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mt-6 space-y-4">
          <div class="form-control">
            <%= f.label :email, class: "label" %>
            <%= f.email_field :email, class: "input input-bordered w-full", autofocus: true, autocomplete: "email" %>
          </div>

          <div class="form-control">
            <%= f.label :password, class: "label" %>
            <%= f.password_field :password, class: "input input-bordered w-full", autocomplete: "current-password" %>
          </div>

          <div class="flex items-center justify-between pt-1">
            <%= link_to t("views.devise.sessions.new.forgot_password"), new_user_password_path, class: "link link-hover text-sm text-gray-500" %>
          </div>

          <div class="pt-2">
            <%= f.submit t("views.devise.sessions.new.submit"), class: "btn btn-primary w-full" %>
          </div>
        </div>
      <% end %>

      <div class="divider my-2 text-xs text-gray-400"><%= t("views.devise.shared.or") %></div>

      <div class="mt-2">
        <%= button_to t("views.devise.sessions.new.line_login"),
          user_line_omniauth_authorize_path,
          method: :post,
          class: "btn btn-success w-full",
          form: { data: { turbo: false } } %>
      </div>

      <div class="text-center text-sm mt-4">
        <%= link_to t("views.devise.sessions.new.sign_up_link"), new_user_registration_path, class: "link link-hover text-gray-500" %>
      </div>
    </div>
  </div>
</div>
