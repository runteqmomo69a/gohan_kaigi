<% if resource.errors.any? %>
  <div class="mt-4 rounded-3xl border border-[#e6b8ab] bg-[#fff3ef] p-5 shadow-sm">
    <div class="flex items-start gap-4">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[#fbe4db] text-[#b96b59]">
        <span class="material-symbols-outlined text-[22px]">error</span>
      </div>
      <div class="min-w-0">
        <p class="font-semibold tracking-wide text-[#9a5b4a]">
        <%= I18n.t(
          "errors.messages.not_saved",
          count: resource.errors.count,
          resource: resource.class.model_name.human
        ) %>
        </p>

        <ul class="mt-3 ml-5 list-disc text-sm leading-relaxed text-[#9a5b4a]">
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>
