<p><%= t("views.devise.mailer.greeting_with_email", email: @email) %></p>

<% if @resource.try(:unconfirmed_email?) %>
  <p><%= t("views.devise.mailer.email_changed.unconfirmed", email: @resource.unconfirmed_email) %></p>
<% else %>
  <p><%= t("views.devise.mailer.email_changed.confirmed", email: @resource.email) %></p>
<% end %>
