<div class="max-w-md mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6"><%= t("views.devise.passwords.new.title") %></h1>

  <p class="text-sm text-gray-600 mb-6">
    <%= t("views.devise.passwords.new.description") %>
  </p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-control mb-6">
      <%= f.label :email, t("views.devise.passwords.new.email_label"), class: "label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
    </div>

    <%= f.submit t("views.devise.passwords.new.submit"), class: "btn btn-primary w-full" %>
  <% end %>

  <div class="mt-4 flex justify-center gap-4 text-sm">
    <%= link_to t("views.devise.passwords.new.back_to_login"), new_user_session_path, class: "link link-hover text-gray-500" %>
    <%= link_to t("views.devise.passwords.new.back_to_top"), root_path, class: "link link-hover text-gray-500" %>
  </div>
</div>
