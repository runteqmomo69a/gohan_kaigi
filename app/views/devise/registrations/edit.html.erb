<h2><%= t("views.devise.registrations.edit.title") %></h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <p><%= f.label :email %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div><%= t("views.devise.registrations.edit.waiting_confirmation", email: resource.unconfirmed_email) %></div>
  <% end %>

  <div class="field">
    <p><%= f.label :password %> <i>(<%= t("views.devise.registrations.edit.password_hint") %>)</i></p>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
    <% if @minimum_password_length %>
      <p><em><%= t("views.devise.registrations.edit.min_password_length", count: @minimum_password_length) %></em></p>
    <% end %>
  </div>

  <div class="field">
    <p><%= f.label :password_confirmation %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <p><%= f.label :current_password %> <i>(<%= t("views.devise.registrations.edit.current_password_hint") %>)</i></p>
    <p><%= f.password_field :current_password, autocomplete: "current-password" %></p>
  </div>

  <div class="actions">
    <%= f.submit t("views.devise.registrations.edit.submit") %>
  </div>
<% end %>

<h3><%= t("views.devise.registrations.edit.cancel_account_title") %></h3>

<div>
  <%= t("views.devise.registrations.edit.cancel_account_prompt") %>
  <%= button_to t("views.devise.registrations.edit.cancel_account_button"),
                registration_path(resource_name),
                data: { confirm: t("views.devise.registrations.edit.cancel_account_confirm"), turbo_confirm: t("views.devise.registrations.edit.cancel_account_confirm") },
                method: :delete %>
</div>

<%= link_to t("common.back"), :back %>
