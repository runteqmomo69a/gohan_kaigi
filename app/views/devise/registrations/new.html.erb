<div class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-[#fbf6ef] via-[#f8f1e7] to-[#f5ede2] flex items-center justify-center px-4 py-10 relative overflow-hidden">
  <div class="absolute top-[-10%] right-[-10%] h-80 w-80 rounded-full bg-[#f4ede3]/70 blur-3xl"></div>
  <div class="absolute bottom-[-10%] left-[-10%] h-72 w-72 rounded-full bg-[#f7efe6]/60 blur-3xl"></div>

  <div class="relative z-10 w-full max-w-md">
    <div class="text-center mb-8">
      <div class="mb-0 inline-flex items-center justify-center">
        <%= image_tag "logo.png", class: "h-[4.5rem] w-[4.5rem] object-contain", alt: t("app.name") %>
      </div>
      <h1 class="brand-title text-3xl font-extrabold tracking-tight text-[#4f2f1d]"><%= t("app.name") %></h1>
      <p class="text-sm text-base-content/60 mt-1"><%= t("views.devise.registrations.new.description") %></p>
    </div>

    <div class="card bg-base-100/95 border border-[#d7cdbc] shadow-xl shadow-orange-200/20">
      <div class="card-body p-7 sm:p-8">
        <h2 class="text-2xl font-bold text-[#4f2f1d]"><%= t("views.devise.registrations.new.title") %></h2>

        <%= render "devise/shared/error_messages", resource: resource %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="mt-5 space-y-4">
            <div class="form-control">
              <%= f.label :name, class: "label text-xs font-bold tracking-widest uppercase text-base-content/60" %>
              <label class="input input-bordered w-full flex items-center gap-2 bg-base-100">
                <span class="material-symbols-outlined text-base-content/40">person</span>
                <%= f.text_field :name, class: "grow border-0 p-0 focus:outline-none", autocomplete: "name" %>
              </label>
            </div>

            <div class="form-control">
              <%= f.label :email, class: "label text-xs font-bold tracking-widest uppercase text-base-content/60" %>
              <label class="input input-bordered w-full flex items-center gap-2 bg-base-100">
                <span class="material-symbols-outlined text-base-content/40">mail</span>
                <%= f.email_field :email, class: "grow border-0 p-0 focus:outline-none", autocomplete: "email" %>
              </label>
            </div>

            <div class="form-control">
              <%= f.label :password, class: "label text-xs font-bold tracking-widest uppercase text-base-content/60" %>
              <label class="input input-bordered w-full flex items-center gap-2 bg-base-100">
                <span class="material-symbols-outlined text-base-content/40">lock</span>
                <%= f.password_field :password, class: "grow border-0 p-0 focus:outline-none", autocomplete: "new-password" %>
              </label>
            </div>

            <div class="form-control">
              <%= f.label :password_confirmation, class: "label text-xs font-bold tracking-widest uppercase text-base-content/60" %>
              <label class="input input-bordered w-full flex items-center gap-2 bg-base-100">
                <span class="material-symbols-outlined text-base-content/40">lock</span>
                <%= f.password_field :password_confirmation, class: "grow border-0 p-0 focus:outline-none", autocomplete: "new-password" %>
              </label>
            </div>

            <div class="pt-1">
              <%= f.submit t("views.devise.registrations.new.submit"), class: "btn w-full rounded-full bg-[#e3744b] text-white border-none hover:bg-[#cf643d] shadow-lg shadow-orange-200/35" %>
            </div>

            <div class="text-center text-sm">
              <%= link_to t("views.devise.registrations.new.login_link"), new_user_session_path, class: "link link-hover text-base-content/60" %>
            </div>
          </div>
        <% end %>

        <div class="divider my-2 text-xs text-base-content/40"><%= t("views.devise.shared.or") %></div>

        <div>
          <%= button_to t("views.devise.registrations.new.line_signup"),
            user_line_omniauth_authorize_path,
            method: :post,
            class: "btn btn-success w-full rounded-full",
            form: { data: { turbo: false } } %>
        </div>
      </div>
    </div>
  </div>
</div>
