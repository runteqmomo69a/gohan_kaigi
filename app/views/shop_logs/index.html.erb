<div class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-[#fbf6ef] via-[#f8f1e7] to-[#f5ede2] px-4 py-8 sm:py-12">
  <div class="mx-auto max-w-7xl space-y-8 sm:space-y-10">
    <section class="relative min-h-[320px] overflow-hidden rounded-[2rem] border border-[#d7cdbc] px-6 py-14 shadow-xl shadow-stone-200/30 sm:px-10 sm:py-16">
      <%= image_tag "shop_log.png",
            class: "absolute inset-0 h-full w-full scale-[1.08] object-cover object-[50%_38%] sm:scale-[1.18] sm:object-[46%_40%]",
            alt: "" %>

      <div class="relative z-10 flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <p class="inline-flex items-center gap-2 rounded-full bg-white/20 backdrop-blur-sm px-3 py-1 text-xs font-bold tracking-widest uppercase text-white">
            <span class="material-symbols-outlined text-sm">menu_book</span>
            <%= t("views.shop_logs.index.hero_badge") %>
          </p>
          <h1 class="mt-4 text-3xl sm:text-4xl font-black tracking-tight leading-tight text-white [text-shadow:0_2px_10px_rgba(0,0,0,0.35)]">
            <%= t("views.shop_logs.index.title") %>
          </h1>
          <p class="mt-3 text-white/95 text-base sm:text-lg [text-shadow:0_1px_8px_rgba(0,0,0,0.35)]">
            <%= t("views.shop_logs.index.description") %>
          </p>
        </div>

        <div class="sm:w-auto lg:self-end lg:mb-1">
          <div class="rounded-3xl border border-white/25 bg-white/16 px-4 py-3 shadow-sm backdrop-blur-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-white/80"><%= t("views.shop_logs.index.stat_logs") %></p>
            <p class="mt-2 text-2xl font-black text-white [text-shadow:0_2px_10px_rgba(0,0,0,0.25)]"><%= @shops.size %></p>
            <p class="mt-1 text-sm text-white/85 [text-shadow:0_1px_8px_rgba(0,0,0,0.25)]"><%= t("views.shop_logs.index.result_count", count: @shops.size) %></p>
          </div>
        </div>
      </div>
    </section>

    <section class="card overflow-hidden border border-[#d7cdbc] bg-base-100/95 shadow-xl shadow-stone-200/20">
      <div class="card-body p-4 sm:p-5">
        <div class="mb-3 flex items-start gap-3">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[#fff1eb] text-[#e3744b]">
            <span class="material-symbols-outlined">filter_list</span>
          </div>
          <div>
            <h2 class="text-xl font-black tracking-tight text-neutral-700 sm:text-2xl"><%= t("views.shop_logs.index.filters_title") %></h2>
            <p class="mt-1 text-sm leading-relaxed text-[#7a6757]"><%= t("views.shop_logs.index.filters_description") %></p>
          </div>
        </div>

        <%= form_with url: shop_logs_path, method: :get, local: true,
          class: "flex flex-col gap-3 xl:flex-row xl:items-end xl:justify-between" do %>

          <div class="form-control w-full xl:max-w-md" data-controller="autocomplete">
            <label class="label text-xs font-bold uppercase tracking-widest text-[#7a6757]">
              <span><%= t("views.shop_logs.index.search") %></span>
            </label>
            <label class="input input-bordered flex w-full items-center gap-3 rounded-2xl bg-base-100 shadow-sm">
              <span class="material-symbols-outlined text-[#e3744b]">search</span>
              <%= text_field_tag :q, params[:q],
                placeholder: t("views.shop_logs.index.search_placeholder"),
                class: "grow border-0 p-0 focus:outline-none",
                data: {
                  autocomplete_target: "input",
                  action: "input->autocomplete#search"
                } %>
            </label>

            <div id="autocomplete-results"
                 data-autocomplete-target="results"
                 class="mt-2 hidden rounded-2xl border border-[#d7cdbc] bg-white shadow-lg shadow-stone-200/15"></div>
          </div>

            <div class="grid w-full gap-4 sm:grid-cols-2 xl:w-auto xl:grid-cols-[150px_170px_auto]">
            <div class="form-control">
              <label class="label text-xs font-bold uppercase tracking-widest text-[#7a6757]">
                <span><%= t("views.shop_logs.index.sort") %></span>
              </label>
              <%= select_tag :sort,
                options_for_select(
                  [
                    [t("views.shop_logs.index.sort_recent"), "recent"],
                    [t("views.shop_logs.index.sort_old"), "old"]
                  ],
                  params[:sort]
                ),
                class: "select select-bordered w-full rounded-2xl bg-base-100 shadow-sm" %>
            </div>

            <div class="form-control">
              <label class="label text-xs font-bold uppercase tracking-widest text-[#7a6757]">
                <span><%= t("views.shop_logs.index.category") %></span>
              </label>
              <%= select_tag :category,
                options_for_select(
                  [[t("views.shop_logs.index.category_all"), ""]] + @categories.map { |c| [c, c] },
                  params[:category]
                ),
                class: "select select-bordered w-full rounded-2xl bg-base-100 shadow-sm" %>
            </div>

            <div class="flex gap-2 sm:col-span-2 xl:col-span-1 xl:justify-end">
              <%= submit_tag t("views.shop_logs.index.search"), class: "btn rounded-full border-none bg-[#e3744b] px-6 text-white hover:bg-[#cf643d] shadow-md shadow-orange-200/35" %>
              <%= link_to t("views.shop_logs.index.reset"), shop_logs_path, class: "btn rounded-full border border-[#d7cdbc] bg-white text-[#7a6757] hover:bg-amber-50" %>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <% if @shops.any? %>
      <section class="space-y-5">
        <% @shops.each do |shop| %>
          <article class="overflow-hidden rounded-[2rem] border border-[#d7cdbc] bg-base-100 shadow-xl shadow-stone-200/20">
            <div class="grid gap-0 xl:grid-cols-[300px_minmax(0,1fr)] 2xl:grid-cols-[340px_minmax(0,1fr)]">
              <div class="relative min-h-[240px] overflow-hidden border-b border-[#d7cdbc] bg-[#fffaf3] xl:min-h-full xl:border-b-0 xl:border-r">
                <% if shop.ogp_image_url.present? %>
                  <%= image_tag shop.ogp_image_url,
                    alt: shop.name,
                    class: "absolute inset-0 h-full w-full object-cover" %>
                  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.06),rgba(0,0,0,0.18))]"></div>
                <% else %>
                  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(0,0,0,0.12))]"></div>
                  <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 translate-y-4">
                    <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-white/90 text-[#e3744b] shadow-sm">
                      <span class="material-symbols-outlined text-[2.25rem]">photo</span>
                    </div>
                    <p class="mt-3 text-sm leading-relaxed text-[#6f5f52]">
                      <%= t("views.shop_logs.index.image_placeholder_body") %>
                    </p>
                  </div>
                <% end %>
              </div>

              <div class="p-6 lg:p-7">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="min-w-0">
                    <% if shop.log_category.present? %>
                      <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold tracking-wide <%= category_color(shop.log_category) %>">
                        <%= shop.log_category %>
                      </span>
                    <% else %>
                      <span class="inline-flex items-center rounded-full bg-[#fff1eb] px-3 py-1 text-xs font-bold tracking-wide text-[#c45f3d]">
                        <%= t("views.shop_logs.index.uncategorized_badge") %>
                      </span>
                    <% end %>

                    <h2 class="mt-3 text-2xl font-black tracking-tight text-neutral-700 sm:text-3xl"><%= shop.name %></h2>
                    <div class="mt-3 flex flex-wrap gap-2 text-sm text-[#7a6757]">
                      <span class="inline-flex items-center gap-2 rounded-full bg-[#fff7ef] px-3 py-1.5">
                        <span class="material-symbols-outlined text-base text-[#8d7766]">event</span>
                        <%= t("views.shop_logs.index.event_label", title: shop.event.title) %>
                      </span>
                      <span class="inline-flex items-center gap-2 rounded-full bg-[#fff7ef] px-3 py-1.5">
                        <span class="material-symbols-outlined text-base text-[#8d7766]">calendar_today</span>
                        <%= t("views.shop_logs.index.created_at_label", date: shop.created_at.strftime("%Y-%m-%d")) %>
                      </span>
                    </div>
                  </div>

                  <div class="flex shrink-0 flex-col gap-2 items-stretch sm:items-end">
                    <% if shop.url.present? %>
                      <%= link_to shop.url,
                        target: "_blank",
                        rel: "noopener",
                        class: "inline-flex items-center justify-center gap-2 rounded-full border border-[#f3c8b8] bg-[#fff1eb] px-4 py-2 text-sm font-medium text-[#e3744b] transition hover:bg-[#fee6dc]" do %>
                        <span class="material-symbols-outlined text-base">open_in_new</span>
                        <span><%= t("views.shop_logs.index.open_shop_page") %></span>
                      <% end %>
                    <% end %>
                  </div>
                </div>

                <div class="mt-6 grid gap-4 xl:grid-cols-[minmax(0,0.95fr)_minmax(280px,1.05fr)]">
                  <section class="rounded-3xl border border-[#d7cdbc] bg-white/80 p-5 shadow-sm">
                    <div class="flex items-center gap-3">
                      <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[#f4ede3] text-[#927765]">
                        <span class="material-symbols-outlined">description</span>
                      </div>
                      <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-[#7a6757]"><%= t("views.shop_logs.index.shop_memo_label") %></p>
                      </div>
                    </div>

                    <% if shop.memo.present? %>
                      <div class="mt-4 max-h-32 overflow-y-auto pr-2">
                        <p class="whitespace-pre-line break-words text-sm leading-relaxed text-[#6f5f52]"><%= shop.memo %></p>
                      </div>
                    <% else %>
                      <div class="mt-4 rounded-2xl border border-dashed border-[#d7cdbc] bg-[#fffaf3] px-4 py-6 text-center text-sm text-[#b0907c]">
                        <%= t("views.shop_logs.index.no_shop_memo") %>
                      </div>
                    <% end %>
                  </section>

                  <section class="rounded-3xl border border-[#d7cdbc] bg-gradient-to-br from-[#fffaf6] to-[#fdf5ec] p-5 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                      <div class="flex items-center gap-3">
                        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[#f7efe6] text-[#b47a61]">
                          <span class="material-symbols-outlined">menu_book</span>
                        </div>
                        <div>
                          <p class="text-xs font-bold uppercase tracking-widest text-[#8b6b5a]"><%= t("views.shop_logs.index.log_note_label") %></p>
                        </div>
                      </div>

                      <%= link_to t("common.edit"),
                        edit_shop_log_path(shop),
                        class: "btn btn-sm rounded-full border border-[#d7cdbc] bg-white text-[#7a6757] hover:bg-amber-50" %>
                    </div>

                    <% if shop.log_note.present? %>
                      <div class="mt-4 max-h-40 overflow-y-auto pr-2">
                        <p class="whitespace-pre-line break-words text-sm leading-relaxed text-[#6f5f52]"><%= shop.log_note %></p>
                      </div>
                    <% else %>
                      <div class="mt-4 rounded-2xl border border-dashed border-[#d7cdbc] bg-white/70 px-4 py-6 text-center text-sm text-[#a78674]">
                        <%= t("views.shop_logs.index.no_log_note") %>
                      </div>
                    <% end %>
                  </section>
                </div>
              </div>
            </div>
          </article>
        <% end %>
      </section>
    <% else %>
      <section class="rounded-[2rem] border border-dashed border-[#d7cdbc] bg-white/80 px-6 py-14 text-center shadow-sm">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-[#fff1eb] text-[#c45f3d]">
          <span class="material-symbols-outlined text-3xl">menu_book</span>
        </div>
        <p class="mt-5 text-base font-medium text-[#7a6757]"><%= t("views.shop_logs.index.empty") %></p>
      </section>
    <% end %>
  </div>
</div>
