<!DOCTYPE html>
<html data-theme="gohan">
  <head>
    <title><%= t("app.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen flex flex-col">
    <%= render "shared/header" %>

  <main class="flex-1 px-4">

    <% flash.each do |type, message| %>
      <% alert_class = type == "notice" ? "alert-success" : "alert-error" %>

      <div class="alert <%= alert_class %> mb-4">
        <span><%= message %></span>
      </div>
    <% end %>

    <%= yield %>

  </main>
  
    <%= render "shared/footer" %>
  </body>
</html>
