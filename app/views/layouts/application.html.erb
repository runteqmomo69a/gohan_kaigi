<!DOCTYPE html>
<html data-theme="gohan">
  <head>
    <title><%= meta_title %></title>
    <meta name="description" content="<%= meta_description %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta property="og:title" content="<%= meta_title %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:type" content="<%= meta_type %>">
    <meta property="og:url" content="<%= meta_url %>">
    <meta property="og:image" content="<%= meta_image_url %>">
    <meta property="og:site_name" content="<%= t('app.name') %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= meta_title %>">
    <meta name="twitter:description" content="<%= meta_description %>">
    <meta name="twitter:image" content="<%= meta_image_url %>">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap">

    <%= favicon_link_tag "favicon/favicon.ico" %>
    <link rel="icon" type="image/png" sizes="32x32" href="<%= asset_path('favicon/favicon-32x32.png') %>">
    <link rel="apple-touch-icon" sizes="180x180" href="<%= asset_path('favicon/apple-touch-icon.png') %>">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen flex flex-col">
    <%= render "shared/header" %>

  <main class="flex-1 px-4">

    <% flash.each do |type, message| %>
      <% is_notice = type.to_s == "notice" %>
      <% flash_classes = if is_notice
           "border-[#c9d8c2] bg-[#f3f7f1] text-[#66785d]"
         else
           "border-[#e6b8ab] bg-[#fff3ef] text-[#9a5b4a]"
         end %>
      <% flash_icon_classes = if is_notice
           "bg-[#e5efe1] text-[#6f8664]"
         else
           "bg-[#fbe4db] text-[#b96b59]"
         end %>
      <% flash_icon = is_notice ? "check_circle" : "error" %>

      <div class="mb-4 rounded-2xl border px-4 py-3 shadow-sm <%= flash_classes %>">
        <div class="flex items-start gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl <%= flash_icon_classes %>">
            <span class="material-symbols-outlined text-[20px]"><%= flash_icon %></span>
          </div>
          <p class="min-w-0 pt-2 text-sm font-medium leading-relaxed"><%= message %></p>
        </div>
      </div>
    <% end %>

    <%= yield %>

  </main>
  
    <%= render "shared/footer" %>
  </body>
</html>
