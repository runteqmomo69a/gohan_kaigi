<header class="navbar border-b border-[#d7cdbc] bg-[#fdf9f3] shadow-sm px-6">
  <div class="flex-1">
    <%= link_to root_path, class: "flex items-center gap-1 text-xl font-bold tracking-tight text-[#4f2f1d]" do %>
      <%= image_tag "logo.png", class: "h-10 w-10 object-contain sm:h-11 sm:w-11", alt: t("app.name") %>
      <span class="brand-title -ml-1 inline-block translate-y-[4px] font-bold"><%= t("app.name") %></span>
    <% end %>
  </div>

  <div class="flex gap-2">
    <%= link_to t("views.devise.shared.links.sign_up"), new_user_registration_path, class: "btn btn-sm rounded-full border-none bg-[#e3744b] text-white hover:bg-[#cf643d]" %>
    <%= link_to t("views.devise.shared.links.log_in"), new_user_session_path, class: "btn btn-outline btn-sm" %>
  </div>
</header>
